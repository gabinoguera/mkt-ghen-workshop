{
  "mcpServers": {
    // ── Razonamiento y contexto ──────────────────────────────────────────
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "sequentialthinking": {
      "type": "stdio",
      "command": "docker",
      "args": ["run", "--rm", "-i", "mcp/sequentialthinking"]
    },

    // ── Navegador ────────────────────────────────────────────────────────
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "concurrent-browser": {
      "type": "stdio",
      "command": "npx",
      "args": ["concurrent-browser-mcp", "--max-instances", "20"]
    },

    // ── GitHub ───────────────────────────────────────────────────────────
    // Token: github.com → Settings → Developer settings → Personal access tokens
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "<YOUR_GITHUB_TOKEN>"
      }
    },

    // ── Diagramas ────────────────────────────────────────────────────────
    "drawio": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@drawio/mcp"]
    },

    // ── Analytics y SEO ──────────────────────────────────────────────────
    // Google Search Console
    // 1. Descarga client_secrets.json de Google Cloud Console
    // 2. Activa "Search Console API" en tu proyecto GCP
    // 3. Coloca el archivo en la raíz del workspace
    "gsc": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-gsc"],
      "env": {
        "GSC_OAUTH_CLIENT_SECRETS_FILE": "./your_client_secrets.json",
        "GSC_DATA_STATE": "all"
      }
    },

    // Google Analytics 4
    // 1. Autentícate con gcloud:
    //    $ gcloud auth application-default login --scopes="openid,https://www.googleapis.com/auth/userinfo.email,https://www.googleapis.com/auth/cloud-platform,https://www.googleapis.com/auth/analytics.readonly"
    // 2. Sustituye los valores con los de tu proyecto y propiedad GA4
    "google-analytics": {
      "type": "stdio",
      "command": "uvx",
      "args": ["analytics-mcp"],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "~/.config/gcloud/application_default_credentials.json",
        "GOOGLE_PROJECT_ID": "<YOUR_GCP_PROJECT_ID>",
        "GA_PROPERTY_ID": "<YOUR_GA4_PROPERTY_ID>"
      }
    }
  }
}
