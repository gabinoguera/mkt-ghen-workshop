# ============================================================
# WORKSPACE CONFIGURATION — copy this to .env and fill in
# ============================================================

# WordPress REST API
# Application Password: generate in WP → Users → Profile → Application Passwords
WORDPRESS_BASE_URL=https://your-site.com
WORDPRESS_USERNAME=your_wp_username
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Google Gemini API (for featured image generation via tools/image_generator.py)
# Get at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
